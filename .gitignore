# Ignore test cache folders
tests/testthat/_cache/
tests/testthat/tests/testthat/_cache/

# Only track docs/ and package source files. Ignore all cache, build, and binary files.

# Keep these folders tracked:
!docs/
!R/
!man/
!data/
!inst/
!tests/
!vignettes/*.Rmd
!DESCRIPTION
!NAMESPACE
!LICENSE*
!*.Rproj

# Ignore everything else by default
/*

