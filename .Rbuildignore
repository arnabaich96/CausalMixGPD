# Ignore temp, hidden, and system folders
^\.tmp/
^\.cursor/
^\.cursor$
^\.vscode/
^\.Rproj.user/
^renv$
^renv\.lock$
^\.githooks$
^\.git$
^\.github$
^\.cache$
^\.cache/
^pkgdown$
^pkgdown/
^Misc$
^codecov\.yml$
^.*\.Rproj$
^\.Rproj\.user$
^docs$
^doc$
^Meta$
# Non-standard top-level files
^DPmixGPD\.code-workspace$
^_pkgdown\.yml$
^build_with_tmp\.ps1$
^data-raw$
^generate_precomputed\.R$
^temp_setup\.txt$
^Rplots\.pdf$
^\.md$
^tools/build_coverage_report.R$
^tools/\.codecov_token$
^vignettes/manuscript/
^vignettes/manuscript/$
^website/
^website/$
^tmp-.*\.R$
^.*\.RData$
^.*\.rdx$
^\.Rhistory$
# Exclude generated .R files from vignettes (knitr artifacts)
^vignettes/.*\.R$
# Exclude .qmd copies of vignettes
^vignettes/.*\.qmd$
# Exclude markdown, qmd, and html files in vignettes folder
^vignettes/.*\.md$
^vignettes/.*\.html$
# CRAN/package-build exclusions (top-level repo artifacts)
^\.lintr$
^\.renvignore$
^\.quartoignore$
^quarto$
^quarto/$
^.*\.yml$
^.*\.md$
^LICENSE$
^codecov\.exe$
^codecov\.asc$
^codecov\.exe\.SHA256SUM$
^codecov\.exe\.SHA256SUM\.sig$
^DPmixGpd\.tex$
^REPO_BLUEPRINT\.md$
^fix_exports\.R$
^temp$
^tests/testthat/_snaps/
^tests/testthat/_snaps$
^tests/testthat/tests/
^tests/testthat/tests/$
^tests/testthat/(?!.*\.R$).*
^build$
^build/
^tools/
^docs$
^site$
^site_libs/$
^site_libs/
^.quarto/
^.quarto/$
^_build/
^_build$
^_freeze/
^_freeze$
