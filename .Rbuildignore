# Ignore temp, hidden, and system folders
^\.tmp/
^\.venv$
^\.venv/
^\.cursor/
^\.cursor$
^\.vscode/
^\.Rproj.user/
^renv$
^renv/
^renv/staging$
^renv/staging/
^renv/staging/.*
^renv\.lock$
^\.githooks$
^\.git$
^\.git/
^\.github$
^\.cache$
^\.cache/
^pkgdown$
^pkgdown/
^Misc$
^codecov\.yml$
^.*\.Rproj$
^\.Rproj\.user$
^docs$
^doc$
^Meta$
# Non-standard top-level files
^cache$
^cache/
^figure$
^figure/
^temp_meta_check\.txt$
^texput\.log$
^CausalMixGPD\.code-workspace$
^_pkgdown\.yml$
