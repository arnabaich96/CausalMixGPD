# Ignore temp, hidden, and system folders
^\.tmp/
^\.vscode/
^\.Rproj.user/
^renv$
^renv\.lock$
^\.githooks$
^\.git$
^\.cache$
^\.cache/
^pkgdown$
^pkgdown/
^vignettes/legacy$
^vignettes/.*\.html$
^vignettes/\.build\.timestamp$
^vignettes/legacy-precomputed$
^vignettes/legacy-precomputed/
^Misc$
^codecov\.yml$
^.*\.Rproj$
^\.Rproj\.user$
^docs$
^doc$
^Meta$
# Non-standard top-level files
^DPmixGPD\.code-workspace$
^_pkgdown\.yml$
^build_with_tmp\.ps1$
^data-raw$
^generate_precomputed\.R$
^temp_setup\.txt$
^Rplots\.pdf$
