# Ignore temp, hidden, and system folders
^\.tmp/
^\.vscode/
^\.Rproj.user/
^renv$
^renv\.lock$
^\.githooks$
^\.git$
^\.cache$
^\.cache/
^pkgdown$
^pkgdown/
^vignettes/legacy$
^vignettes/.*\.html$
^vignettes/\.build\.timestamp$
^vignettes/legacy-precomputed$
^vignettes/legacy-precomputed/
^vignettes$
^Misc$
^codecov\.yml$
^.*\.Rproj$
^\.Rproj\.user$
^docs$