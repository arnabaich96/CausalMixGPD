# Ignore temp, hidden, and system folders
^\.tmp/
^\.vscode/
^\.Rproj.user/
^renv$
^renv\.lock$
^\.githooks$
^\.git$
^\.github$
^\.cache$
^\.cache/
^pkgdown$
^pkgdown/
^Misc$
^codecov\.yml$
^.*\.Rproj$
^\.Rproj\.user$
^docs$
^doc$
^Meta$
# Non-standard top-level files
^DPmixGPD\.code-workspace$
^_pkgdown\.yml$
^build_with_tmp\.ps1$
^data-raw$
^generate_precomputed\.R$
^temp_setup\.txt$
^Rplots\.pdf$
^README\.md$
^tools/build_coverage_report.R$
^tools/\.codecov_token$
^vignettes/manuscript/
^vignettes/manuscript/$
^vignettes/workflows/
^vignettes/workflows/$
^vignettes/customization/
^vignettes/customization/$
