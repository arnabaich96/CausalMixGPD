^vignettes/renv$
^website$
^website/
^tmp-.*\.R$
^.*\.RData$
^.*\.rdx$
^\.Rhistory$
# Exclude generated .R files from vignettes (knitr artifacts)
^vignettes/.*\.R$
# Exclude .qmd copies of vignettes
^vignettes/.*\.qmd$
# Exclude markdown, qmd, and html files in vignettes folder
^vignettes/.*\.md$
^vignettes/.*\.html$
# CRAN/package-build exclusions (top-level repo artifacts)
^\.lintr$
^\.renvignore$
^\.quartoignore$
^quarto$
^quarto/$
^.*\.yml$
^.*\.md$
^LICENSE$
^codecov\.exe$
^codecov\.asc$
