manuscript_dir <- local({
  input_dir <- tryCatch(
    knitr::current_input(dir = TRUE),
    error = function(e) ""
  )
  candidates <- unique(c(
    if (nzchar(input_dir)) input_dir,
    file.path("vignettes", "manuscript"),
    "."
  ))
  for (candidate in candidates) {
    if (!nzchar(candidate)) {
      next
    }
    if (file.exists(file.path(candidate, "CausalMixGPD_JSS_article.Rnw")) &&
        dir.exists(file.path(candidate, "assets"))) {
      return(normalizePath(candidate, winslash = "/", mustWork = TRUE))
    }
  }
  stop("Could not locate the manuscript directory from the current working directory.", call. = FALSE)
})

