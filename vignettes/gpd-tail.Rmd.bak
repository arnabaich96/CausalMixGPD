```{r setup, include=FALSE}
knitr::opts_chunk$set(collapse = TRUE, comment = "#>")
library(DPmixGPD)
library(nimble)
source("_helpers.R")
```

```{r data}
data("nc_pos_tail200_k4")
print_dataset_header(nc_pos_tail200_k4, "nc_pos_tail200_k4")
```

```{r gpd-fit, eval=FALSE}
mcmc <- default_mcmc()
pos_kernels <- c("gamma", "lognormal", "invgauss", "amoroso")
backends <- c("crp", "sb")

for (ker in pos_kernels) {
  for (backend in backends) {
    bundle <- build_nimble_bundle(
      y = nc_pos_tail200_k4$y,
      backend = backend,
      kernel = ker,
      GPD = TRUE,
      components = nc_pos_tail200_k4$meta$K_true,
      mcmc = mcmc
    )
    summary(bundle)
    fit <- run_mcmc_bundle_manual(bundle, show_progress = FALSE)
    summary(fit)
    predict(fit, y = sort(nc_pos_tail200_k4$y), type = "survival")
  }
}
```
