local({
    info <- loadingNamespaceInfo()
    pkg <- info$pkgname
    ns <- .getNamespace(as.name(pkg))
    if (is.null(ns))
        stop("cannot find namespace environment for ", pkg, domain = NA);
    dbbase <- file.path(info$libname, pkg, "R", pkg)
    lazyLoad(dbbase, ns, filter = function(n) n != ".__NAMESPACE__.")
setHook(packageEvent(pkg, "onLoad"), function(...) options(covr.record_tests = FALSE))
setHook(packageEvent(pkg, "onLoad"), function(...) covr:::trace_environment(ns))
reg.finalizer(ns, function(...) { covr:::save_trace(Sys.getenv("COVERAGE_DIR", "D:/Git-Repos/CausalMixGPD-Package/CausalMixGPD/covr/debug-lib-tests")) }, onexit = TRUE)
})
